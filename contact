<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Contact Us | 2SD Toxicology Services</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #042C53;
    --navy-mid: #0C447C;
    --blue: #185FA5;
    --blue-light: #378ADD;
    --sky: #85B7EB;
    --sky-pale: #E6F1FB;
    --teal: #1D9E75;
    --teal-dark: #0F6E56;
    --teal-pale: #E1F5EE;
    --teal-mid: #9FE1CB;
    --offwhite: #F7F6F2;
    --text: #1A1A18;
    --text-muted: #5F5E5A;
    --gradient-teal: linear-gradient(135deg, #1D9E75, #0F6E56);
    --gradient-blue: linear-gradient(135deg, #185FA5, #042C53);
    --glass-bg: rgba(255, 255, 255, 0.05);
    --glass-border: rgba(255, 255, 255, 0.1);
    --border-light: rgba(29,158,117,0.2);
    --border-glow: 0 0 8px rgba(29,158,117,0.3);
  }

  /* Creamy + 50% Navy Blue Mix Background (same as about page) */
  body {
    font-family: 'DM Sans', sans-serif;
    background: #F5F2EC;
    background: linear-gradient(145deg, #F5F2EC 0%, #E8ECF0 30%, #8BA0B5 70%, #5B6F82 100%);
    color: var(--text);
    overflow-x: hidden;
  }

  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #C5D0D8; border-radius: 10px; }
  ::-webkit-scrollbar-thumb { background: linear-gradient(135deg, var(--teal), var(--blue)); border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: linear-gradient(135deg, var(--teal-dark), var(--navy)); }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 130px;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.9s cubic-bezier(0.2, 0.9, 0.4, 1.1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .btn-primary {
    background: var(--gradient-teal);
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    border: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(29,158,117,0.3);
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }
  .btn-primary:hover::before {
    width: 300px;
    height: 300px;
  }
  .btn-primary:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 30px rgba(29,158,117,0.5);
  }

  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(4, 44, 83, 0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border);
    padding: 0 32px;
    height: 75px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'DM Serif Display', serif;
    font-size: 24px;
    color: white;
    text-decoration: none;
    background: var(--gradient-teal);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .logo span {
    background: linear-gradient(135deg, var(--teal-mid), white);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }
  .nav-links a {
    color: rgba(255,255,255,0.8);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gradient-teal);
    transition: width 0.3s;
    border-radius: 2px;
  }
  .nav-links a:hover::after {
    width: 100%;
  }
  .nav-links a:hover { color: white; }
  .nav-cta {
    background: var(--gradient-teal);
    padding: 8px 22px;
    border-radius: 50px;
    color: white !important;
  }
  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(29,158,117,0.3);
  }
  .hamburger {
    display: none;
    flex-direction: column;
    cursor: pointer;
    gap: 5px;
  }
  .hamburger span {
    width: 26px;
    height: 2px;
    background: white;
    transition: all 0.3s ease;
  }
  .mobile-menu {
    position: fixed;
    top: 75px;
    left: -100%;
    width: 80%;
    height: calc(100vh - 75px);
    background: rgba(4, 44, 83, 0.98);
    backdrop-filter: blur(20px);
    transition: left 0.3s ease;
    z-index: 99;
    padding: 40px 32px;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .mobile-menu.active { left: 0; }
  .mobile-menu a {
    color: white;
    font-size: 18px;
    text-decoration: none;
    font-weight: 500;
  }
  .mobile-menu .mobile-cta {
    background: var(--gradient-teal);
    padding: 12px 20px;
    border-radius: 50px;
    text-align: center;
    margin-top: 20px;
  }

  /* Hero Section */
  .hero {
    background: linear-gradient(145deg, #042C53 0%, #0a3a6b 100%);
    min-height: 45vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: 120px 0 80px;
    border-bottom: 1px solid var(--border-light);
  }
  #particles-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 850px;
    margin: 0 auto;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(29,158,117,0.15);
    border: 1px solid rgba(29,158,117,0.4);
    border-radius: 50px;
    padding: 6px 20px;
    font-size: 12px;
    font-weight: 600;
    color: var(--teal-mid);
    margin-bottom: 28px;
    backdrop-filter: blur(8px);
  }
  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 64px;
    line-height: 1.08;
    margin-bottom: 20px;
  }
  .gradient-text {
    background: linear-gradient(135deg, #ffffff, var(--sky), var(--teal-mid));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-tagline {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Who We Serve Bar */
  .serve-wrapper {
    background: rgba(15, 110, 86, 0.95);
    backdrop-filter: blur(16px);
    position: sticky;
    top: 75px;
    z-index: 50;
    width: 100%;
    border-bottom: 2px solid var(--teal);
    box-shadow: var(--border-glow);
    overflow: hidden;
  }
  .serve-container {
    display: flex;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
  }
  .serve-label-static {
    background: rgba(0,0,0,0.4);
    padding: 8px 20px;
    border-radius: 40px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: white;
    white-space: nowrap;
    margin-left: 20px;
    margin-right: 10px;
    z-index: 10;
    flex-shrink: 0;
  }
  .serve-scroll {
    flex: 1;
    overflow: hidden;
    padding: 12px 0;
  }
  .serve-track {
    display: inline-block;
    white-space: nowrap;
    animation: scrollRightToLeft 25s linear infinite;
  }
  .serve-wrapper:hover .serve-track {
    animation-play-state: paused;
  }
  .serve-item {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: white;
    letter-spacing: 0.3px;
    margin: 0 25px;
  }
  .serve-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: var(--teal-mid);
    border-radius: 50%;
    margin: 0 8px;
    vertical-align: middle;
  }
  @keyframes scrollRightToLeft {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Contact Section */
  .contact-section {
    padding: 80px 0;
    background: transparent;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }

  /* Contact Form */
  .contact-form {
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    border-radius: 28px;
    padding: 40px;
    border: 1px solid var(--border-light);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }
  .contact-form h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 32px;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .contact-form p {
    color: var(--text-muted);
    margin-bottom: 30px;
    font-size: 14px;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    transition: all 0.3s;
    background: rgba(255,255,255,0.9);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(29,158,117,0.1);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .submit-btn {
    background: var(--gradient-teal);
    color: white;
    padding: 14px 28px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    width: 100%;
    transition: all 0.3s;
  }
  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(29,158,117,0.3);
  }

  /* Contact Info & Map */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  .info-card {
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    border-radius: 24px;
    padding: 25px;
    border: 1px solid var(--border-light);
    transition: all 0.3s;
  }
  .info-card:hover {
    border-color: var(--teal);
    box-shadow: var(--border-glow);
    background: rgba(255,255,255,0.98);
  }
  .info-card i {
    font-size: 32px;
    color: var(--teal);
    margin-bottom: 15px;
  }
  .info-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .info-card p, .info-card a {
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    line-height: 1.6;
  }
  .info-card a:hover {
    color: var(--teal);
  }
  .map-card {
    padding: 0;
    overflow: hidden;
  }
  .map-card iframe {
    width: 100%;
    height: 250px;
    border: none;
  }
  .business-hours {
    padding: 15px 20px;
    border-top: 1px solid var(--border-light);
  }
  .business-hours p {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 13px;
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, #042C53 0%, #0a3a6b 100%);
    padding: 70px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--border-light);
  }
  .cta-section::before {
    content: '';
    position: absolute;
    width: 150%;
    height: 150%;
    top: -25%;
    left: -25%;
    background: radial-gradient(circle, rgba(29,158,117,0.08) 0%, transparent 70%);
    animation: rotateSlow 25s linear infinite;
  }
  @keyframes rotateSlow {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .cta-section h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 42px;
    color: white;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }
  .cta-section p {
    color: rgba(255,255,255,0.7);
    margin-bottom: 32px;
    font-size: 16px;
    position: relative;
    z-index: 1;
  }

  /* Footer */
  footer {
    background: linear-gradient(135deg, #021c33 0%, #01101f 100%);
    padding: 60px 0 30px;
    border-top: 1px solid var(--border-light);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 45px;
    margin-bottom: 40px;
  }
  .footer-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 24px;
    color: white;
    display: block;
    margin-bottom: 18px;
    text-decoration: none;
    background: var(--gradient-teal);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .footer-address {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin-bottom: 18px;
  }
  .footer-phone {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    display: block;
    margin-bottom: 10px;
  }
  .footer-phone:hover { color: var(--teal-mid); }
  .footer-col h4 {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 22px;
  }
  .footer-col ul {
    list-style: none;
  }
  .footer-col ul li {
    margin-bottom: 12px;
  }
  .footer-col ul a {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    transition: all 0.3s;
  }
  .footer-col ul a:hover {
    color: var(--teal-mid);
    transform: translateX(6px);
    display: inline-block;
  }
  .social-icons {
    display: flex;
    gap: 18px;
    margin-top: 25px;
  }
  .social-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: white;
    text-decoration: none;
    font-size: 19px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .social-icon:hover {
    transform: translateY(-5px);
    border-color: transparent;
  }
  .social-icon.fa-facebook-f:hover { background: #1877F2; box-shadow: 0 5px 20px rgba(24,119,242,0.4); }
  .social-icon.fa-twitter:hover { background: #1DA1F2; box-shadow: 0 5px 20px rgba(29,161,242,0.4); }
  .social-icon.fa-linkedin-in:hover { background: #0077B5; box-shadow: 0 5px 20px rgba(0,119,181,0.4); }
  .social-icon.fa-envelope:hover { background: #D44638; box-shadow: 0 5px 20px rgba(212,70,56,0.4); }
  .footer-bottom {
    text-align: center;
    padding-top: 35px;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 12px;
    color: rgba(255,255,255,0.3);
  }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .container { padding: 0 24px; }
    .hero h1 { font-size: 42px; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .form-row { grid-template-columns: 1fr; gap: 15px; }
    .footer-grid { grid-template-columns: 1fr; gap: 38px; }
    .serve-label-static { font-size: 10px; padding: 5px 12px; margin-left: 12px; }
    .serve-item { font-size: 12px; margin: 0 15px; }
    .contact-form { padding: 25px; }
  }
</style>
</head>
