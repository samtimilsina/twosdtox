</ul>

<!-- Hero Section -->
<section class="hero">
  <canvas id="particles-canvas"></canvas>
  <div class="hero-content reveal">
    <div class="hero-badge">✦ Get in Touch ✦</div>
    <h1>
      <span class="gradient-text">Contact Us</span>
    </h1>
    <p class="hero-tagline">Have questions? We're here to help. Reach out to our team of experts.</p>
  </div>
</section>

<!-- Who We Serve Bar -->
<div class="serve-wrapper">
  <div class="serve-container">
    <div class="serve-label-static">
      <i class="fas fa-users" style="margin-right: 6px;"></i> Who we serve
    </div>
    <div class="serve-scroll">
      <div class="serve-track">
        <span class="serve-item">Medical Devices</span><span class="serve-dot"></span>
        <span class="serve-item">In Vitro Diagnostics</span><span class="serve-dot"></span>
        <span class="serve-item">Pharmaceutical Packaging</span><span class="serve-dot"></span>
        <span class="serve-item">Biomaterials</span><span class="serve-dot"></span>
        <span class="serve-item">Drug-Device Combinations</span><span class="serve-dot"></span>
        <span class="serve-item">Cosmetics</span><span class="serve-dot"></span>
        <span class="serve-item">Food Packaging</span><span class="serve-dot"></span>
        <span class="serve-item">Medical Devices</span><span class="serve-dot"></span>
        <span class="serve-item">In Vitro Diagnostics</span><span class="serve-dot"></span>
        <span class="serve-item">Pharmaceutical Packaging</span><span class="serve-dot"></span>
        <span class="serve-item">Biomaterials</span><span class="serve-dot"></span>
        <span class="serve-item">Drug-Device Combinations</span><span class="serve-dot"></span>
        <span class="serve-item">Cosmetics</span><span class="serve-dot"></span>
        <span class="serve-item">Food Packaging</span>
      </div>
    </div>
  </div>
</div>

<!-- Contact Section -->
<section class="contact-section">
  <div class="container">
    <div class="contact-grid">
      
      <!-- Contact Form -->
      <div class="contact-form reveal">
        <h2>Make an Appointment</h2>
        <p>Fill out the form below and we'll get back to you within 24 hours.</p>
        
        <form id="contactForm" action="#" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label>Full Name *</label>
              <input type="text" name="name" placeholder="John Doe" required>
            </div>
            <div class="form-group">
              <label>Email Address *</label>
              <input type="email" name="email" placeholder="john@example.com" required>
            </div>
          </div>
          
          <div class="form-group">
            <label>Address</label>
            <input type="text" name="address" placeholder="Street, City, State, Zip">
          </div>
          
          <div class="form-group">
            <label>Interested in *</label>
            <select name="interest" required>
              <option value="">Select an option</option>
              <option>Medical Device Biocompatibility evaluation</option>
              <option>Toxicological Risk assessment</option>
              <option>Clinical laboratory compliance</option>
              <option>Interpretation of a clinical and forensic toxicology reports</option>
              <option>High resolution mass spectrometry studies/consultation</option>
              <option>Laboratory information and quality management software</option>
              <option>Other</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Message (Optional)</label>
            <textarea name="message" rows="4" placeholder="Tell us more about your needs..."></textarea>
          </div>
          
          <button type="submit" class="submit-btn">Send Message <i class="fas fa-paper-plane"></i></button>
        </form>
      </div>
      
